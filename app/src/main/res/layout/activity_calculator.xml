<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNavigation"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kalkulator Inwestycji"
            android:textColor="@color/gold"
            android:textSize="24sp"
            android:layout_marginBottom="30dp" />

        <EditText
            android:id="@+id/kwotaPoczatkowa"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Kwota początkowa (zł)"
            android:inputType="numberDecimal"
            android:background="@color/card"
            android:textColor="@color/white"
            android:textColorHint="@color/gray"
            android:paddingLeft="10dp"
            android:layout_marginBottom="15dp" />

        <EditText
            android:id="@+id/oprocentowanie"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Oprocentowanie roczne (%)"
            android:inputType="numberDecimal"
            android:background="@color/card"
            android:textColor="@color/white"
            android:textColorHint="@color/gray"
            android:paddingLeft="10dp"
            android:layout_marginBottom="15dp" />

        <EditText
            android:id="@+id/liczbaLat"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Liczba lat"
            android:inputType="number"
            android:background="@color/card"
            android:textColor="@color/white"
            android:textColorHint="@color/gray"
            android:paddingLeft="10dp"
            android:layout_marginBottom="25dp" />

        <Button
            android:id="@+id/przyciskOblicz"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Oblicz zysk"
            android:backgroundTint="@color/gold"
            android:textColor="@color/dark" />

        <TextView
            android:id="@+id/wynikInwestycji"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="18sp" />
    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/card"
        app:itemIconTint="@color/gold"
        app:itemTextColor="@color/white"
        app:menu="@menu/bottom_nav_menu" />

</RelativeLayout>